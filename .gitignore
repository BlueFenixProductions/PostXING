# Version stamp (generated each build by version.mjs; not committed)
.version

# Build output
**/bin/
**/obj/
**/AppPackages/
**/BundleArtifacts/
**/GeneratedArtifacts/
**/.vs/
# Ignore editor-local VSCode/VSCodium files, but commit the shared workspace
# config (issue #22: 2-space XAML for VSCodium).
**/.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.user
*.suo
*.userosscache
*.sln.docstates

# Test / coverage
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx

# NuGet
*.nupkg
*.snupkg
.nuget/

# MAUI / Xamarin
*.binlog

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp

# Claude-managed (per-developer, refetchable)
.agents/
.claude/skills/
.impeccable/
.claude/settings.local.json

# Per-developer first-run Settings seed (personal defaults baked into the local build only).
# defaults.local.example.json is the committed template; the real file stays out of the public repo.
defaults.local.json
