<?xml version="1.0" encoding="utf-8"?>
<!--
  Adds the repo root as a local NuGet source so that the
  Microsoft.NETFramework.ReferenceAssemblies package (shipped as net20ref.nupkg
  alongside this file) can be restored even when an upstream PackageSourceMapping
  rule blocks nuget.org from serving it.

  The .NET SDK auto-injects Microsoft.NETFramework.ReferenceAssemblies as a
  dependency for any net20-targeted SDK-style project. Without this config, on
  machines with restrictive PackageSourceMapping enabled, restore fails with:
    NU1100: Unable to resolve 'Microsoft.NETFramework.ReferenceAssemblies'
            ... PackageSourceMapping is enabled ...

  This file is additive: other configured sources/mappings continue to apply
  to other packages. We only register a local source and claim the
  ReferenceAssemblies package pattern for it.
-->
<configuration>
  <packageSources>
    <add key="local-refassemblies" value="." />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="local-refassemblies">
      <package pattern="Microsoft.NETFramework.ReferenceAssemblies*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
