<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
	<application android:allowBackup="true" android:icon="@mipmap/appicon" android:roundIcon="@mipmap/appicon_round" android:supportsRtl="true"></application>
	<!-- INTERNET is the standard MAUI Android baseline (kept for the WebView host and a future
	     GitHub-over-HTTP path). The v1 Android flow is local-files-only; ACCESS_NETWORK_STATE is
	     omitted because nothing checks connectivity. The package name is injected from ApplicationId
	     (net.bluefenix.postxing) by the MAUI build. -->
	<uses-permission android:name="android.permission.INTERNET" />
</manifest>
