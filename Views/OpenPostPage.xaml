<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PostXING.App.ViewModels"
             x:Class="PostXING.App.Views.OpenPostPage"
             x:DataType="vm:OpenPostViewModel"
             x:Name="ThisPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
             Shell.NavBarIsVisible="False"
             Title="Open post">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Label Grid.Column="0" Text="Open post" FontSize="18" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}" />
            <Button Grid.Column="1" Text="Settings" Command="{Binding OpenSettingsCommand}" />
        </Grid>

        <Label Grid.Row="1" Text="{Binding StatusMessage}" FontSize="11" TextColor="{StaticResource Muted}" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Entries}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PostEntry">
                    <Grid Padding="8,4" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="{Binding DisplayName}" FontSize="13" FontFamily="HackRegular"
                               TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Path=BindingContext.SelectCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Grid.Column="1" Text="{Binding Tag}" FontSize="11" TextColor="{StaticResource Muted}" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <HorizontalStackLayout Grid.Row="3" Spacing="12" HorizontalOptions="End">
            <Button Text="Cancel" Command="{Binding CancelCommand}" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
