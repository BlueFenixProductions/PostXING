<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PostXING.ViewModels;assembly=PostXING.ViewModels"
             x:Class="PostXING.App.Views.PreviewPage"
             x:DataType="vm:PreviewViewModel"
             BackgroundColor="{DynamicResource Surface}"
             Shell.NavBarIsVisible="False"
             Title="Preview">
  <Grid RowDefinitions="*,Auto">
    <WebView Grid.Row="0" x:Name="PreviewWebView" BackgroundColor="Transparent"
             SemanticProperties.Description="Rendered preview of the current post" />

    <Grid Grid.Row="1" Padding="6,4" ColumnDefinitions="Auto,*,Auto">
      <Button Grid.Column="0" Text="back" Command="{Binding CloseCommand}"
              Style="{StaticResource StatusBarButton}"
              SemanticProperties.Description="Back to editor" />
      <Label Grid.Column="1" Style="{StaticResource Kicker}" Text="[ preview ]"
             HorizontalOptions="Center" VerticalOptions="Center" />
      <Button Grid.Column="2" Text="refresh" Command="{Binding RefreshCommand}"
              Style="{StaticResource StatusBarButton}"
              SemanticProperties.Description="Re-render the preview" />
    </Grid>
  </Grid>
</ContentPage>
