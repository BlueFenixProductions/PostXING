<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PostXING.App.ViewModels"
             x:Class="PostXING.App.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
             Shell.NavBarIsVisible="False"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" MaximumWidthRequest="600" HorizontalOptions="Center">
            <Label Text="Settings" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}" />

            <Label Text="Repository" FontSize="11" TextColor="{StaticResource Muted}" />
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="owner" Text="{Binding Owner}" />
                <Label Grid.Column="1" Text="/" VerticalOptions="Center" TextColor="{StaticResource Muted}" />
                <Entry Grid.Column="2" Placeholder="repo" Text="{Binding Repo}" />
            </Grid>

            <Label Text="Content root (folder for posts)" FontSize="11" TextColor="{StaticResource Muted}" />
            <Entry Placeholder="content/posts" Text="{Binding ContentRoot}" />

            <Label Text="Integration branch" FontSize="11" TextColor="{StaticResource Muted}" />
            <Entry Placeholder="develop" Text="{Binding DevelopBranch}" />

            <BoxView HeightRequest="1" Color="{StaticResource Muted}" Opacity="0.3" Margin="0,8" />

            <Label Text="GitHub authentication" FontSize="11" TextColor="{StaticResource Muted}" />
            <Label Text="{Binding GhAuthDetail}" FontSize="12" TextColor="{StaticResource Muted}" />
            <HorizontalStackLayout Spacing="8">
                <Button Text="Re-check gh auth" Command="{Binding CheckAuthCommand}" IsEnabled="{Binding IsBusy, Converter={x:Null}}" />
            </HorizontalStackLayout>
            <Label FontSize="11" TextColor="{StaticResource Muted}"
                   Text="PAT is managed by the gh CLI. To add one: open cmd and run &#10;&#10;    echo YOUR_PAT | gh auth login --with-token&#10;&#10;Then click Re-check above." />

            <BoxView HeightRequest="1" Color="{StaticResource Muted}" Opacity="0.3" Margin="0,8" />

            <HorizontalStackLayout Spacing="12" HorizontalOptions="End">
                <Button Text="Cancel" Command="{Binding CancelCommand}" />
                <Button Text="Save" Command="{Binding SaveCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
