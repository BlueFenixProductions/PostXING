<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PostXING.App.ViewModels"
             x:Class="PostXING.App.Views.EditorPage"
             x:DataType="vm:EditorViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
             Shell.NavBarIsVisible="False">
    <ContentPage.Resources>
        <Style TargetType="Label" x:Key="StatusLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{StaticResource Muted}" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="*,Auto">
            <Editor Grid.Row="0"
                    Text="{Binding RawMarkdown, Mode=TwoWay}"
                    AutoSize="TextChanges"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}"
                    FontFamily="HackRegular"
                    FontSize="14"
                    Margin="2"
                    Placeholder="Start writing..."
                    PlaceholderColor="{StaticResource Muted}" />

            <Grid Grid.Row="1" Padding="6,4" ColumnDefinitions="Auto,*,Auto">
                <HorizontalStackLayout Grid.Column="0" Spacing="12">
                    <Label Style="{StaticResource StatusLabel}" Text="New">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NewPostCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Style="{StaticResource StatusLabel}" Text="Open">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenPostCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Style="{StaticResource StatusLabel}" Text="Settings">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Style="{StaticResource StatusLabel}" Text="Save" IsVisible="{Binding IsDirty}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Style="{StaticResource StatusLabel}" Text="Publish" IsVisible="{Binding IsDirty}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PublishCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="16">
                    <Label Style="{StaticResource StatusLabel}" Text="{Binding SaveStatus}" />
                    <Label Style="{StaticResource StatusLabel}" Text="{Binding CurrentPath}" />
                    <Label Style="{StaticResource StatusLabel}" Text="{Binding WordCount, StringFormat='{0} words'}" />
                    <Label Style="{StaticResource StatusLabel}" Text="{Binding ReadingTimeMinutes, StringFormat='{0} min'}" />
                    <Label Style="{StaticResource StatusLabel}" Text="{Binding GhAuthStatus}" />
                </HorizontalStackLayout>
            </Grid>
        </Grid>

        <!-- Title prompt overlay -->
        <Grid IsVisible="{Binding ShowTitlePrompt}"
              BackgroundColor="{AppThemeBinding Light=#80000000, Dark=#A0000000}">
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Padding="56"
                    Margin="64"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    StrokeShape="RoundRectangle 8,8,8,8">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="32">
                    <Label Grid.Row="0" Text="What are we writing about?" FontSize="32"
                           TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}" />

                    <VerticalStackLayout Grid.Row="1" Spacing="24" VerticalOptions="Center">
                        <Entry Placeholder="Post title" Text="{Binding PromptTitle}"
                               FontSize="28"
                               HeightRequest="72"
                               BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}" />
                        <Entry Placeholder="Author (optional)" Text="{Binding PromptAuthor}"
                               FontSize="18"
                               BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light={StaticResource InkLight}, Dark={StaticResource InkDark}}" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Row="2" Spacing="12" HorizontalOptions="End">
                        <Button Text="Cancel" Command="{Binding CancelTitlePromptCommand}" />
                        <Button Text="Start writing" Command="{Binding ConfirmTitlePromptCommand}" />
                    </HorizontalStackLayout>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
