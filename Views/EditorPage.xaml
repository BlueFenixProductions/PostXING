<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PostXING.ViewModels;assembly=PostXING.ViewModels"
             x:Class="PostXING.App.Views.EditorPage"
             x:DataType="vm:EditorViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource Paper100}, Dark={StaticResource Ink950}}"
             Shell.NavBarIsVisible="False">
    <!-- Minimum-chrome MenuBar: only canonical Windows keyboard accelerators live here.
         All visible affordances stay in the status bar at the bottom of the editor. -->
    <ContentPage.MenuBarItems>
        <MenuBarItem Text="post">
            <MenuFlyoutItem Text="new" Command="{Binding NewPostCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="N" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="open" Command="{Binding OpenPostCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="O" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="save" Command="{Binding SaveCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="S" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="publish" Command="{Binding PublishCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl,Shift" Key="P" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="settings" Command="{Binding SettingsCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="," />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
        </MenuBarItem>
        <MenuBarItem Text="help">
            <MenuFlyoutItem Text="about" Command="{Binding AboutCommand}" />
        </MenuBarItem>
    </ContentPage.MenuBarItems>

    <Grid>
        <Grid RowDefinitions="*,Auto">
            <WebView Grid.Row="0"
                     x:Name="EditorWebView"
                     BackgroundColor="Transparent"
                     SemanticProperties.Description="Post body"
                     SemanticProperties.Hint="The Markdown body of the current post, with GitHub Dark Colorblind syntax highlighting for frontmatter and markdown." />

            <Grid Grid.Row="1" Padding="6,4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                <HorizontalStackLayout Grid.Column="0" Spacing="2">
                    <Button Text="new" Command="{Binding NewPostCommand}"
                            Style="{StaticResource StatusBarButton}"
                            SemanticProperties.Description="New post" />
                    <Button Text="open" Command="{Binding OpenPostCommand}"
                            Style="{StaticResource StatusBarButton}"
                            SemanticProperties.Description="Open post" />
                    <Button Text="settings" Command="{Binding SettingsCommand}"
                            Style="{StaticResource StatusBarButton}"
                            SemanticProperties.Description="Settings" />
                    <Button Text="about" Command="{Binding AboutCommand}"
                            Style="{StaticResource StatusBarButton}"
                            SemanticProperties.Description="About PostXING" />
                    <Button Text="save" Command="{Binding SaveCommand}"
                            IsVisible="{Binding IsDirty}"
                            Style="{StaticResource StatusBarButton}"
                            TextColor="{StaticResource PhoenixBlue}"
                            SemanticProperties.Description="Save post" />
                    <Button Text="publish" Command="{Binding PublishCommand}"
                            IsVisible="{Binding IsDirty}"
                            Style="{StaticResource StatusBarButton}"
                            TextColor="{AppThemeBinding Light={StaticResource ForgeAmberDeep}, Dark={StaticResource ForgeAmber}}"
                            SemanticProperties.Description="Publish post" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="16">
                    <Label Style="{StaticResource StatusBarRead}" Text="{Binding SaveStatus}" />
                    <Label Style="{StaticResource StatusBarRead}" Text="{Binding CurrentPath}" />
                    <Label Style="{StaticResource StatusBarRead}" Text="{Binding WordCount, StringFormat='{0} words'}"
                           TextColor="{AppThemeBinding Light={StaticResource SignalCyanDeep}, Dark={StaticResource SignalCyan}}" />
                    <Label Style="{StaticResource StatusBarRead}" Text="{Binding ReadingTimeMinutes, StringFormat='{0} min'}"
                           TextColor="{AppThemeBinding Light={StaticResource SignalCyanDeep}, Dark={StaticResource SignalCyan}}" />
                    <Label Style="{StaticResource StatusBarRead}" Text="{Binding GhAuthStatus}"
                           TextColor="{AppThemeBinding Light={StaticResource ForgeAmberDeep}, Dark={StaticResource ForgeAmber}}" />
                </HorizontalStackLayout>
            </Grid>
        </Grid>

        <!-- Title prompt overlay: the one sanctioned modal moment. -->
        <Grid IsVisible="{Binding ShowTitlePrompt}"
              BackgroundColor="{StaticResource Scrim}">
            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource Ink850}"
                    Padding="56"
                    Margin="64"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    StrokeShape="RoundRectangle 8,8,8,8">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="32">
                    <Label Grid.Row="0" Text="What are we writing about?" FontSize="32"
                           FontFamily="HackBold"
                           TextColor="{StaticResource Paper100}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <VerticalStackLayout Grid.Row="1" Spacing="24" VerticalOptions="Center">
                        <Entry Placeholder="Post title" Text="{Binding PromptTitle}"
                               FontSize="28"
                               HeightRequest="72"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource Paper100}"
                               PlaceholderColor="{StaticResource Paper500}"
                               SemanticProperties.Description="Post title"
                               ReturnType="Next"
                               ReturnCommand="{Binding ConfirmTitlePromptCommand}" />
                        <Entry Placeholder="Author (optional)" Text="{Binding PromptAuthor}"
                               FontSize="18"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource Paper300}"
                               PlaceholderColor="{StaticResource Paper500}"
                               SemanticProperties.Description="Post author"
                               ReturnType="Done"
                               ReturnCommand="{Binding ConfirmTitlePromptCommand}" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Row="2" Spacing="12" HorizontalOptions="End">
                        <Button Text="cancel" Command="{Binding CancelTitlePromptCommand}"
                                Style="{StaticResource ButtonGhost}"
                                SemanticProperties.Description="Cancel new post" />
                        <Button Text="start writing" Command="{Binding ConfirmTitlePromptCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                SemanticProperties.Description="Start writing post" />
                    </HorizontalStackLayout>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
