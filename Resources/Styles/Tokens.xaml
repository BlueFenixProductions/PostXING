<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
  <!-- Semantic theme tokens (MD3-style roles). The XAML binds these via {DynamicResource}; the
       runtime ThemeApplicator overwrites each key for the active theme (Services/ThemeApplicator.cs).
       Seeded with the Phoenix (dark, brand default) palette so DynamicResource lookups resolve
       correctly before the applicator runs and on design-time/hot-reload. -->
  <Color x:Key="Surface">#0F0F1F</Color>
  <Color x:Key="SurfaceVariant">#1A1A2E</Color>
  <Color x:Key="OnSurface">#E5E7EB</Color>
  <Color x:Key="OnSurfaceStrong">#FFFFFF</Color>
  <Color x:Key="OnSurfaceVariant">#9095A4</Color>
  <Color x:Key="OnSurfaceFaint">#9095A4</Color>
  <Color x:Key="Primary">#1E5BFF</Color>
  <Color x:Key="PrimaryHover">#4D7DFF</Color>
  <Color x:Key="PrimaryPressed">#0A2BC2</Color>
  <Color x:Key="OnPrimary">#FFFFFF</Color>
  <Color x:Key="KickerAccent">#06B6D4</Color>
  <Color x:Key="PublishAccent">#E08A2E</Color>
  <Color x:Key="FocusRing">#06B6D4</Color>
  <Color x:Key="Outline">#2D2D4A</Color>
  <Color x:Key="OutlineVariant">#2D2D4A</Color>
  <Color x:Key="GhostHoverSurface">#1A1A2E</Color>
  <Color x:Key="DisabledSurface">#2D2D4A</Color>
  <Color x:Key="Scrim">#8C000000</Color>
</ResourceDictionary>
