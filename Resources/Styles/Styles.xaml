<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!-- Primary action button: themed primary background, on-primary label,
       11pt Hack caps-mono at 0.14em tracking, 4px corner, 44px height. -->
  <Style x:Key="ButtonPrimary" TargetType="Button">
    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
    <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
    <Setter Property="FontFamily" Value="HackBold" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HeightRequest" Value="44" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="Padding" Value="22,0" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryHover}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Focused">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryHover}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Pressed">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryPressed}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{DynamicResource DisabledSurface}" />
              <Setter Property="TextColor" Value="{DynamicResource OnSurfaceFaint}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!-- Ghost button: transparent background, on-surface label, 1px outline. -->
  <Style x:Key="ButtonGhost" TargetType="Button">
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
    <Setter Property="BorderColor" Value="{DynamicResource Outline}" />
    <Setter Property="BorderWidth" Value="1" />
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HeightRequest" Value="44" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="Padding" Value="22,0" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="BorderColor" Value="{DynamicResource OnSurface}" />
              <Setter Property="BackgroundColor" Value="{DynamicResource GhostHoverSurface}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Focused">
            <VisualState.Setters>
              <Setter Property="BorderColor" Value="{DynamicResource FocusRing}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{DynamicResource OnSurfaceFaint}" />
              <Setter Property="BorderColor" Value="{DynamicResource Outline}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!-- Status-bar tap button: borderless 11pt Hack caps-mono, 44px target, focus-visible ring. -->
  <Style x:Key="StatusBarButton" TargetType="Button">
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="TextColor" Value="{DynamicResource OnSurfaceVariant}" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="BorderColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HeightRequest" Value="44" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{DynamicResource OnSurfaceStrong}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Focused">
            <VisualState.Setters>
              <Setter Property="BorderWidth" Value="1" />
              <Setter Property="BorderColor" Value="{DynamicResource FocusRing}" />
              <Setter Property="TextColor" Value="{DynamicResource OnSurfaceStrong}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{DynamicResource OnSurfaceFaint}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!-- Status-bar read label (right cluster: SaveStatus, CurrentPath, WordCount, etc.)
       Themed muted role to keep AA contrast on the surface in every theme. -->
  <Style x:Key="StatusBarRead" TargetType="Label">
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextColor" Value="{DynamicResource OnSurfaceVariant}" />
    <Setter Property="VerticalOptions" Value="Center" />
  </Style>

  <!-- Bracketed kicker: section labels in the theme accent caps-mono. Bind Text="[ section name ]". -->
  <Style x:Key="Kicker" TargetType="Label">
    <Setter Property="FontFamily" Value="HackBold" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="TextColor" Value="{DynamicResource KickerAccent}" />
    <Setter Property="VerticalOptions" Value="Center" />
  </Style>

  <!-- Field caption beneath a form field (Settings page). 11pt mono, themed muted. -->
  <Style x:Key="FieldCaption" TargetType="Label">
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextColor" Value="{DynamicResource OnSurfaceVariant}" />
  </Style>

  <!-- Hairline divider, themed. -->
  <Style x:Key="Hairline" TargetType="BoxView">
    <Setter Property="HeightRequest" Value="1" />
    <Setter Property="Color" Value="{DynamicResource OutlineVariant}" />
    <Setter Property="Margin" Value="0,16" />
  </Style>

  <!-- Implicit Entry style: brand-aligned text field. -->
  <Style TargetType="Entry">
    <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceVariant}" />
    <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
    <Setter Property="PlaceholderColor" Value="{DynamicResource OnSurfaceFaint}" />
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="MinimumHeightRequest" Value="44" />
  </Style>

</ResourceDictionary>
