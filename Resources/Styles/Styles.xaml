<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!-- Primary action button: phoenix-blue background, paper-100 label,
       11pt Hack caps-mono at 0.14em tracking, 4px corner, 44px height. -->
  <Style x:Key="ButtonPrimary" TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource PhoenixBlue}" />
    <Setter Property="TextColor" Value="{StaticResource Paper100}" />
    <Setter Property="FontFamily" Value="HackBold" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HeightRequest" Value="44" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="Padding" Value="22,0" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{StaticResource PhoenixBlueHover}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Focused">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{StaticResource PhoenixBlueHover}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Pressed">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{StaticResource PhoenixBlueDeep}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{StaticResource Ink700}" />
              <Setter Property="TextColor" Value="{StaticResource Paper500}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!-- Ghost button: transparent background, paper-300/ink-950 label, 1px border. -->
  <Style x:Key="ButtonGhost" TargetType="Button">
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource Ink950}, Dark={StaticResource Paper300}}" />
    <Setter Property="BorderColor"
            Value="{AppThemeBinding Light={StaticResource Paper500}, Dark={StaticResource Ink700}}" />
    <Setter Property="BorderWidth" Value="1" />
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HeightRequest" Value="44" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="Padding" Value="22,0" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="BorderColor"
                      Value="{AppThemeBinding Light={StaticResource Ink950}, Dark={StaticResource Paper300}}" />
              <Setter Property="BackgroundColor"
                      Value="{AppThemeBinding Light={StaticResource Paper300}, Dark={StaticResource Ink850}}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Focused">
            <VisualState.Setters>
              <Setter Property="BorderColor" Value="{StaticResource SignalCyan}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{StaticResource Paper500}" />
              <Setter Property="BorderColor" Value="{StaticResource Ink700}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!-- Status-bar tap button: borderless 11pt Hack caps-mono, 44px target, focus-visible cyan ring. -->
  <Style x:Key="StatusBarButton" TargetType="Button">
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="TextColor" Value="{StaticResource Paper500}" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="BorderColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HeightRequest" Value="44" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="TextColor"
                      Value="{AppThemeBinding Light={StaticResource Ink950}, Dark={StaticResource Paper100}}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Focused">
            <VisualState.Setters>
              <Setter Property="BorderWidth" Value="1" />
              <Setter Property="BorderColor" Value="{StaticResource SignalCyan}" />
              <Setter Property="TextColor"
                      Value="{AppThemeBinding Light={StaticResource Ink950}, Dark={StaticResource Paper100}}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{StaticResource Ink700}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!-- Status-bar read label (right cluster: SaveStatus, CurrentPath, WordCount, etc.)
       Theme-aware to maintain AA contrast on Paper100 in light mode. -->
  <Style x:Key="StatusBarRead" TargetType="Label">
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource Paper600}, Dark={StaticResource Paper500}}" />
    <Setter Property="VerticalOptions" Value="Center" />
  </Style>

  <!-- Bracketed kicker: section labels in cyan caps-mono. Bind Text="[ section name ]"
       Light mode uses the deeper cyan for AA contrast. -->
  <Style x:Key="Kicker" TargetType="Label">
    <Setter Property="FontFamily" Value="HackBold" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="CharacterSpacing" Value="2" />
    <Setter Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource SignalCyanDeep}, Dark={StaticResource SignalCyan}}" />
    <Setter Property="VerticalOptions" Value="Center" />
  </Style>

  <!-- Field caption beneath a form field (Settings page). 11pt mono, theme-aware muted. -->
  <Style x:Key="FieldCaption" TargetType="Label">
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource Paper600}, Dark={StaticResource Paper500}}" />
  </Style>

  <!-- Hairline divider, theme-aware. -->
  <Style x:Key="Hairline" TargetType="BoxView">
    <Setter Property="HeightRequest" Value="1" />
    <Setter Property="Color"
            Value="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />
    <Setter Property="Margin" Value="0,16" />
  </Style>

  <!-- Implicit Entry style: brand-aligned text field. -->
  <Style TargetType="Entry">
    <Setter Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource Paper100}, Dark={StaticResource Ink850}}" />
    <Setter Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource Ink950}, Dark={StaticResource Paper300}}" />
    <Setter Property="PlaceholderColor" Value="{StaticResource Paper500}" />
    <Setter Property="FontFamily" Value="HackRegular" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="MinimumHeightRequest" Value="44" />
  </Style>

</ResourceDictionary>
